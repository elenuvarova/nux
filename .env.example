PORT=3001
NODE_ENV=development

# Leave DATABASE_URL blank locally — the backend uses SQLite automatically.
# In production (Coolify), set DATABASE_URL to the internal Postgres
# connection string. Coolify-internal Postgres needs NO SSL.
#   DATABASE_URL=postgres://postgres:PASSWORD@<container-name>:5432/postgres
# For an external managed DB (e.g. Neon) that requires TLS, also set:
#   DATABASE_SSL=true
# DATABASE_URL=
# DATABASE_SSL=false

# ─── AI / Curator (server-side only — NEVER exposed to the frontend) ───
# The Curator feature calls the PRIMARY provider and automatically fails over
# to the OTHER on rate-limit / error, so set BOTH for redundancy.
# Local dev: put the real values in backend/.env (gitignored).
# Production: set these as env vars in Coolify.
#   Gemini key → https://aistudio.google.com/apikey
#   Groq key   → https://console.groq.com/keys
# GEMINI_API_KEY=
# GROQ_API_KEY=
# Optional tuning (defaults baked in):
# AI_PRIMARY=gemini                 # gemini | groq (the other is the fallback)
# GEMINI_MODEL=gemini-2.0-flash
# GROQ_MODEL=llama-3.3-70b-versatile
